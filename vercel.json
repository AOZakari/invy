{
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "0 * * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.invy.rsvp"
        }
      ],
      "destination": "https://invy.rsvp/:path*",
      "permanent": true
    }
  ]
}
